# Google GenAI Agent - Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git (it's in .gitignore)

# Google API Key - Get from https://aistudio.google.com/app/apikeys
GOOGLE_API_KEY=your-api-key-here

# For Vertex AI (optional)
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Optional: Set model (default is gemini-1.5-flash)
# GOOGLE_MODEL=gemini-1.5-flash

# Optional: For proxy/network settings
# HTTP_PROXY=
# HTTPS_PROXY=
